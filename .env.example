# Paperclip Configuration for Railway Deployment

# Database (Railway Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/paperclip_db

# API Keys & Secrets
PAPERCLIP_AGENT_JWT_SECRET=your_jwt_secret_here
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
